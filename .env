# ── User service ────────────────────────────────────────────────────────────
USER_APP_PORT=6969
USER_LOG_LEVEL=info
USER_DB_PORT=5433
USER_DB_USER=postgres
USER_DB_PASSWORD=postgres
USER_DB_NAME=user_db
USER_DB_SSLMODE=disable
USER_DB_MAX_OPEN_CONNS=25
USER_DB_MAX_IDLE_CONNS=25
USER_DB_CONN_MAX_LIFETIME=5m
USER_DB_CONN_MAX_IDLE_TIME=5m
USER_CORS_ALLOWED_ORIGINS=*
USER_RATE_LIMIT_REQUESTS=100
USER_RATE_LIMIT_WINDOW=1m

# ── Catalog service ──────────────────────────────────────────────────────────
CATALOG_APP_PORT=7070
CATALOG_LOG_LEVEL=info
CATALOG_DB_PORT=5434
CATALOG_DB_USER=postgres
CATALOG_DB_PASSWORD=postgres
CATALOG_DB_NAME=catalog_db
CATALOG_DB_SSLMODE=disable
CATALOG_DB_MAX_OPEN_CONNS=25
CATALOG_DB_MAX_IDLE_CONNS=25
CATALOG_DB_CONN_MAX_LIFETIME=5m
CATALOG_DB_CONN_MAX_IDLE_TIME=5m
CATALOG_CORS_ALLOWED_ORIGINS=*
CATALOG_RATE_LIMIT_REQUESTS=100
CATALOG_RATE_LIMIT_WINDOW=1m

# ── Shared Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=/app/deploy/kong/jwt.key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
COOKIE_SECURE=false

# ── Kong API Gateway ─────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_ADMIN_PORT=8002

# ── PgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
