# ── Auth service ─────────────────────────────────────────────────────────────
AUTH_APP_PORT=6868
AUTH_LOG_LEVEL=info
AUTH_CORS_ALLOWED_ORIGINS=https://yourdomain.com   # never use * in production
USER_GRPC_TIMEOUT=5s              # deadline for every auth -> user gRPC call

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate keys:
#   openssl genrsa -out deploy/kong/jwt.key 2048
#   openssl rsa -in deploy/kong/jwt.key -pubout -out deploy/kong/jwt.key.pub
JWT_PRIVATE_KEY_PATH=/app/deploy/kong/jwt.key
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
COOKIE_SECURE=true               # must be true in production (requires HTTPS)

# ── User service ────────────────────────────────────────────────────────────
USER_APP_PORT=6969
USER_GRPC_PORT=6970
USER_LOG_LEVEL=info
USER_DB_PORT=5433
USER_DB_USER=postgres
USER_DB_PASSWORD=<change-me>
USER_DB_NAME=user_db
USER_DB_SSLMODE=require          # set to 'disable' only for local dev
USER_DB_MAX_OPEN_CONNS=25
USER_DB_MAX_IDLE_CONNS=25
USER_DB_CONN_MAX_LIFETIME=5m
USER_DB_CONN_MAX_IDLE_TIME=5m
USER_CORS_ALLOWED_ORIGINS=https://yourdomain.com   # never use * in production

# ── Shared Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6380
REDIS_PASSWORD=<change-me>
REDIS_DB=0

# ── Kong API Gateway ─────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_ADMIN_PORT=8002

# ── PgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=<change-me>
PGADMIN_PORT=5050
